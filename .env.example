# Turso cloud database (get from turso.io)
DATABASE_URL=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# Apify scraper (get from apify.com)
APIFY_API_TOKEN=your-apify-token

# Gemini AI summary (get from aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Weekly digest email (get API key from resend.com — free tier: 3k/month)
# Only sent after scheduled runs (GitHub Actions cron), not manual ones.
RESEND_API_KEY=your-resend-api-key
DIGEST_EMAIL_TO=you@example.com

# Groq (free, fast inference for low-priority LLM tasks like post re-categorization)
# Get a key from console.groq.com/keys. Falls back to keyword-only categorization if unset.
GROQ_API_KEY=your-groq-api-key

# Obsidian sync (optional — writes a standalone vault of company notes for
# bipartite client↔competitor graph view). Filesystem-direct: just point at
# a folder you'll open as a *separate* Obsidian vault. Don't reuse a vault
# that contains other notes — the sync deletes stale .md files in this dir.
OBSIDIAN_VAULT_PATH=C:\Users\amitf\Documents\Projects\personal progects\client tracker

# Slack real-time alerts (optional — sends high-strength signals to Slack
# within minutes of detection, instead of waiting for the weekly email).
# Create an Incoming Webhook at https://api.slack.com/apps and paste the
# URL here. Skipped silently if unset.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# Minimum strength to fire (default 70): personnel_move=100, comment=80,
# repost=60, like=40, mention=30. Set lower to alert more aggressively.
SLACK_MIN_STRENGTH=70
# Optional overrides:
# DIGEST_EMAIL_FROM=CyberTracker <onboarding@resend.dev>
# DIGEST_APP_URL=https://linkedin-tracker-production-4f02.up.railway.app
